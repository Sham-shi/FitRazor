<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitRazor.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Мои переменные -->
    <link rel="stylesheet" href="~/css/MyCSS/variables.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/MyCSS/components.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/MyCSS/Index/base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MyCSS/Index/trainer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MyCSS/Index/philosophy.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MyCSS/Index/zone.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MyCSS/Index/abonement.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/MyCSS/Index/contact.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/MyCSS/layout.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/MyCSS/responsive.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/FitRazor.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    @* Шрифты *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Montserrat:wght@300;400;700&display=swap" rel="stylesheet">
</head>

@{
        var currentPage = ViewContext.RouteData.Values["Page"]?.ToString();
}

<body class="d-flex flex-column min-vh-100 bg-dark text-white">

    <!-- ===== ВЕРХНИЙ ХЕДЕР (контакты + лого) ===== -->
    <header class="top-header border-bottom border-secondary-subtle">
        <div class="container py-2">
            <div class="row align-items-center g-3">

                <!-- Логотип -->
                <div class="col-auto">
                    <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none"
                       asp-area="" asp-page="/Index">
                        <img src="~/Images/G&P_logo4.png"
                             alt="Gains&Pains"
                             width="60" height="60"
                             class="brand-logo">
                        <span class="brand-name text-uppercase fw-bold">
                            Gains<span class="text-danger">&</span>Pains
                        </span>
                    </a>
                </div>

                <!-- Телефон и соцсети (справа) -->
                <div class="col d-flex align-items-center justify-content-end gap-4">

                    <!-- Телефон -->
                    <a href="tel:+79999999999"
                       class="header-phone d-flex align-items-center gap-2 text-decoration-none">
                        <i class="bi bi-telephone-fill text-danger" aria-hidden="true"></i>
                        <span class="d-none d-sm-inline">+7 (999) 999-99-99</span>
                    </a>

                    <!-- Соцсети -->
                    <div class="social-links d-flex align-items-center gap-2">
                        <a href="https://rutube.ru/"
                           class="social-icon social-rutube"
                           aria-label="Rutube"
                           target="_blank">
                            Rutube
                        </a>
                        <a href="https://t.me/"
                           class="social-icon social-telegram"
                           aria-label="Telegram"
                           target="_blank">
                            Telegram
                        </a>
                        <a href="https://vk.com/"
                           class="social-icon social-vk"
                           aria-label="VKontakte"
                           target="_blank">
                            VK
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- ===== НИЖНЕЕ МЕНЮ (навигация) ===== -->
    <nav class="navbar navbar-expand-md main-nav sticky-top border-bottom" data-bs-theme="dark">
        <div class="container">

            <!-- Гамбургер для мобильных -->
            <button class="navbar-toggler border-0"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Меню">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Ссылки навигации -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto text-uppercase">
                    <li class="nav-item">
                        <a class="nav-link nav-link-dark @(currentPage == "/Index" ? "active" : "")"
                           asp-area="" asp-page="/Index">
                            Главная
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link nav-link-dark @(currentPage == "/Privacy" ? "active" : "")"
                           asp-area="" asp-page="/Privacy">
                            О разработчике
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Кнопки справа: Вход + Админ -->
            <div class="d-flex align-items-center gap-2">

                <!-- Кнопка входа (открывает модалку) -->
                <button type="button"
                        class="btn btn-outline-primary-glow btn-sm text-uppercase"
                        data-bs-toggle="modal"
                        data-bs-target="#login">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Войти
                </button>

                <!-- Кнопка админ-панели (offcanvas) -->
                <button class="btn btn-link text-muted p-0 gp-btn-admin"
                        type="button"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#adminMenu"
                        aria-controls="adminMenu"
                        aria-label="Панель администратора">
                    <i class="bi bi-gear-fill"></i>
                </button>
            </div>
        </div>
    </nav>

    <!-- ===== ОСНОВНОЙ КОНТЕНТ ===== -->
    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- ===== ФУТЕР ===== -->
    <footer class="footer mt-auto py-4 border-top border-secondary-subtle">
        <div class="container">
            <div class="row align-items-center g-3">

                <!-- Копирайт -->
                <div class="col-md-6 text-center text-md-start">
                    <small class="text-muted">
                        &copy; 2026 Gains & Pains — <a href="/privacy" class="text-decoration-none text-muted hover-red">О РАЗРАБОТЧИКЕ</a>
                    </small>
                </div>

                <!-- Доп. ссылки (опционально) -->
                <div class="col-md-6 text-center text-md-end">
                    <small class="text-muted">
                        <a href="/privacy" class="text-decoration-none text-muted hover-red me-3">Политика</a>
                        <a href="#contact" class="text-decoration-none text-muted hover-red">Контакты</a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- ===== МОДАЛЬНОЕ ОКНО ВХОДА ===== -->
    <div class="modal fade modal-dark" id="login" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-uppercase fw-bold text-primary-light">Авторизация</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>

                <div class="modal-body pt-0">
                    <form method="post" class="form-dark">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input type="email" class="form-control form-dark-input" id="email" placeholder="" name="Email" required>
                            <label for="email" class="form-dark-label">Email</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="password" class="form-control form-dark-input pe-5" id="password" placeholder="" name="Password" required>
                            <label for="password" class="form-dark-label">Пароль</label>

                            <!-- Показать/скрыть пароль -->
                            <button type="button" class="btn gp-btn-eye position-absolute top-50 end-0 translate-middle-y me-3"
                                    id="togglePassword" aria-label="Показать пароль">
                                <i class="bi bi-eye-slash" id="eyeSlash"></i>
                                <i class="bi bi-eye d-none" id="eye"></i>
                            </button>
                        </div>

                        <button type="submit" class="btn btn-primary-glow w-100 text-uppercase fw-bold">
                            Войти
                        </button>
                    </form>
                </div>

                <div class="modal-footer border-0 justify-content-center">
                    <a href="/register" class="small text-muted text-decoration-none hover-red">Зарегистрироваться</a>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== OFFCANVAS АДМИН-ПАНЕЛЬ ===== -->
    <div class="offcanvas offcanvas-start offcanvas-dark"
         id="adminMenu"
         tabindex="-1"
         aria-labelledby="adminMenuLabel">

        <div class="offcanvas-header border-bottom border-secondary-subtle">
            <h5 class="offcanvas-title text-uppercase fw-bold text-primary-light" id="adminMenuLabel">
                <i class="bi bi-shield-lock me-2"></i>Админ-панель
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
        </div>

        <div class="offcanvas-body">
            <ul class="navbar-nav gap-2">
                <li class="nav-item">
                    <a class="nav-link nav-link-dark" asp-page="/Index">
                        <i class="bi bi-house me-2"></i>Главная
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link nav-link-dark" asp-page="/Privacy">
                        <i class="bi bi-person me-2"></i>О разработчике
                    </a>
                </li>
                <li class="nav-item mt-3 pt-3 border-top border-secondary-subtle">
                    <small class="text-uppercase small fw-bold d-block mb-2">Управление</small>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-dark"
                       asp-page="/Entities/Index"
                       asp-route-entityName="Trainers">
                        <i class="bi bi-people me-2"></i>Тренеры
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-dark"
                       asp-page="/Entities/Index"
                       asp-route-entityName="Clients">
                        <i class="bi bi-person-badge me-2"></i>Клиенты
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-dark"
                       asp-page="/Entities/Index"
                       asp-route-entityName="Services">
                        <i class="bi bi-list-task me-2"></i>Услуги
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-dark"
                       asp-page="/Entities/Index"
                       asp-route-entityName="TrainerServices">
                        <i class="bi bi-link-45deg me-2"></i>Тренеры-Услуги
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link nav-link-dark"
                       asp-page="/Entities/Index"
                       asp-route-entityName="Bookings">
                        <i class="bi bi-calendar-check me-2"></i>Записи
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Скрипты -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
